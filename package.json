{
	"name": "docloop-ai",
	"version": "1.10.3",
	"description": "GitHub Action to automatically generate and update README files using AI",
	"keywords": [
		"ai",
		"documentation",
		"github-actions",
		"readme"
	],
	"license": "MIT",
	"author": "",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"test:local": "bun scripts/test-local.ts",
		"act:test": "act pull_request -W .github/workflows/test-local.yml --secret-file .secrets --container-architecture linux/amd64 -s GITHUB_TOKEN=$GITHUB_TOKEN",
		"format": "oxfmt --ignore-path .oxfmtignore --write .",
		"format:check": "oxfmt --ignore-path .oxfmtignore --check .",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"knip": "knip",
		"prepare": "husky"
	},
	"dependencies": {
		"@actions/core": "^3.0.1",
		"@actions/exec": "^3.0.0",
		"@actions/github": "^9.1.1",
		"normalize-path": "^3.0.0",
		"openai": "^4.28.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/bun": "^1.3.13",
		"@types/node": "^20.11.0",
		"@types/normalize-path": "^3.0.2",
		"husky": "^9.1.7",
		"knip": "^6.7.0",
		"lint-staged": "^16.4.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"semantic-release": "^23.0.0",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,md,yml,yaml}": "oxfmt --write",
		"*.{ts,tsx}": "oxlint --fix"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
