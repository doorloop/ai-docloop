{
	"name": "docloop-ai",
	"version": "1.6.0",
	"description": "GitHub Action to automatically generate and update README files using AI",
	"keywords": [
		"ai",
		"documentation",
		"github-actions",
		"readme"
	],
	"license": "MIT",
	"author": "",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:local": "bun scripts/test-local.ts",
		"act:test": "act pull_request -W .github/workflows/test-local.yml --secret-file .secrets --container-architecture linux/amd64 -s GITHUB_TOKEN=$GITHUB_TOKEN",
		"format": "oxfmt --ignore-path .oxfmtignore --write .",
		"format:check": "oxfmt --ignore-path .oxfmtignore --check .",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"knip": "knip",
		"release": "bun scripts/release/index.ts",
		"prepare": "bun run build"
	},
	"dependencies": {
		"@actions/core": "^1.10.1",
		"@actions/exec": "^1.1.1",
		"@actions/github": "^6.0.0",
		"normalize-path": "^3.0.0",
		"openai": "^4.28.0"
	},
	"devDependencies": {
		"@types/inquirer": "^9.0.3",
		"@types/jest": "^29.5.12",
		"@types/node": "^20.11.0",
		"@types/normalize-path": "^3.0.2",
		"inquirer": "^9.2.12",
		"jest": "^29.7.0",
		"knip": "^6.7.0",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"semantic-release": "^23.0.0",
		"ts-jest": "^29.1.2",
		"tsup": "^8.0.1",
		"typescript": "^5.3.3"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
