{
	"name": "docloop-ai",
	"version": "1.1.0",
	"description": "GitHub Action to automatically generate and update README files using AI",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsup src/index.ts --format cjs --platform node --target node20 --out-dir dist --no-splitting --clean",
		"typecheck": "tsc --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:local": "tsx scripts/test-local.ts",
		"act:test": "act pull_request -W .github/workflows/test-local.yml --secret-file .secrets --container-architecture linux/amd64 -s GITHUB_TOKEN=$GITHUB_TOKEN",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
		"format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
		"release": "tsx scripts/release/index.ts",
		"prepare": "npm run build"
	},
	"keywords": [
		"github-actions",
		"readme",
		"ai",
		"documentation"
	],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@actions/core": "^1.10.1",
		"@actions/exec": "^1.1.1",
		"@actions/github": "^6.0.0",
		"normalize-path": "^3.0.0",
		"openai": "^4.28.0"
	},
	"devDependencies": {
		"@types/jest": "^29.5.12",
		"@types/node": "^20.11.0",
		"@types/normalize-path": "^3.0.2",
		"jest": "^29.7.0",
		"ts-jest": "^29.1.2",
		"tsup": "^8.0.1",
		"tsx": "^4.7.0",
		"typescript": "^5.3.3",
		"inquirer": "^9.2.12",
		"@types/inquirer": "^9.0.3",
		"prettier": "^3.2.5",
		"semantic-release": "^23.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
